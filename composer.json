{
    "name": "phalanx/stoa",
    "description": "HTTP server framework for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": ["http", "server", "routing", "async", "fastroute", "reactphp"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-stoa",
    "require": {
        "php": "^8.4",
        "phalanx/aegis": "^0.5",
        "nikic/fast-route": "^2.0",
        "react/datagram": "^1.10",
        "react/http": "^1.10"
    },
    "suggest": {
        "symfony/runtime": "For Symfony Runtime integration via PhalanxHttpRunner",
        "phalanx/styx": "For streaming responses",
        "phalanx/hydra": "For worker process parallelism in request handlers"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Stoa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Tests\\Stoa\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.5-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
